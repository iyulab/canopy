{
  "name": "@iyulab/canopy",
  "version": "0.0.0",
  "description": "Publishing renderer: turn a tree of markdown notes into a static website.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "canopy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome lint ./src",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.2.0",
    "github-slugger": "^2.0.0",
    "katex": "^0.17.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
